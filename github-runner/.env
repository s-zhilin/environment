# repo  — раннер для одного репозитория (заполните REPO_URL)
# org   — раннер для организации (заполните ORG_NAME)
RUNNER_SCOPE=repo

# Для RUNNER_SCOPE=repo:
REPO_URL=https://github.com/OWNER/REPO
# Для RUNNER_SCOPE=org:
ORG_NAME=

# GitHub Personal Access Token (classic) с правом `repo` (или `admin:org` для org-раннера).
# Используется только для получения регистрационного токена.
ACCESS_TOKEN=

RUNNER_NAME=core-runner

# true — раннер выполняет один job и пересоздаётся (чище, но нужен restart)
EPHEMERAL=false
